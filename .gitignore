# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env_example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── uv ────────────────────────────────────────────────────────────────────────
.uv/

# ── OS files ──────────────────────────────────────────────────────────────────
*.DS_Store
data/.DS_Store

# ── Output files (large, generated) ──────────────────────────────────────────
outputs/
Final_outputs/
analysis_improvemnets/
config/
data/

# ── Docs (generated, not tracked) ────────────────────────────────────────────
IMPROVEMENTS.md
ANALYSIS.md
README.md

# ── annotation-platform: curated data + its own docs ARE tracked ─────────────
# (the broad data/ and README.md rules above are unanchored and would
# otherwise also catch these nested paths)
!annotation-platform/data/
!annotation-platform/data/**
!annotation-platform/README.md
