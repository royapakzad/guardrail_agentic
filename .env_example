# ── LLM provider API keys ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
MISTRAL_API_KEY=...

# ── Web search backend ────────────────────────────────────────────────────────
# Select backend: duckduckgo (default, no key) | searxng | tavily
# TAVILY_API_KEY is only needed when --web-search-tool tavily is used.
TAVILY_API_KEY=tvly-...

# SearXNG: only needed when --web-search-tool searxng is used.
# Run: docker run -d -p 8080:8080 searxng/searxng
SEARXNG_BASE_URL=http://localhost:8080

# ── Otari gateway (PR #14 — optional) ────────────────────────────────────────
# Otari lets you manage provider keys centrally and track LLM usage.
# Setup:
#   1. Otari dashboard → Providers → add your Anthropic/OpenAI/etc. API keys
#   2. Otari dashboard → API Keys → generate a platform token
#   3. Set LLM_GATEWAY=otari and OTARI_AI_TOKEN below
# Leave LLM_GATEWAY unset to call providers directly (default).
# LLM_GATEWAY=otari
# OTARI_AI_TOKEN=<token from Otari dashboard → API Keys>
# OTARI_API_BASE=https://api.otari.ai   # optional: only for self-hosted instances

# ── Domain tool groups (PR #18 — optional) ────────────────────────────────────
# Humanitarian group (--tool-group humanitarian): GDACS + WHO need no key.
# ReliefWeb v2 needs a free approved appname — request one at
# https://apidoc.reliefweb.int/ and set it here:
RELIEFWEB_APPNAME=
