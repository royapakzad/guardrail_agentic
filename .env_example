# Copy this file to .env and fill in the values you need.
# Do NOT commit .env — it is listed in .gitignore.

# ── LLM provider API keys (need at least one) ────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=

# ── Web-search backends for the agentic guardrail (optional) ─────────────────
# DuckDuckGo (default) needs no key.
# Tavily backend (managed search + extract API):
TAVILY_API_KEY=
# SearXNG backend (self-hosted; point at your instance):
SEARXNG_BASE_URL=http://localhost:8080
