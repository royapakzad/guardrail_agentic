# Copy this file to .env and fill in the values you need.
# Do NOT commit .env — it is listed in .gitignore.

# ── LLM provider API keys (need at least one) ────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=

# ── Web-search backends for the agentic guardrail (optional) ─────────────────
# DuckDuckGo (default) needs no key.
# Tavily backend (managed search + extract API):
TAVILY_API_KEY=
# SearXNG backend (self-hosted; point at your instance):
SEARXNG_BASE_URL=http://localhost:8080

# ── LLM gateway (optional) ───────────────────────────────────────────────────
# Route every completion through the Otari gateway (budgets, virtual keys, usage
# tracking). Default is "direct" (call providers directly using the keys above).
# Requires `uv sync --extra otari`.
LLM_GATEWAY=direct                       # set to "otari" to route through the gateway
OTARI_API_BASE=                          # e.g. http://localhost:8000/v1
OTARI_API_KEY=                           # virtual key issued by the gateway
OTARI_PLATFORM_TOKEN=                    # only for the hosted otari.ai control plane
